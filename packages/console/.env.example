# Database Configuration
DATABASE_URL=postgresql://localhost:5432/observability

# Hasura Configuration
VITE_GRAPHQL_ENDPOINT=http://localhost:8080/v1/graphql
VITE_HASURA_ADMIN_SECRET=your-hasura-admin-secret

# Grafana Loki Configuration (Optional - for log viewing)
# Get these from your Grafana Cloud account
VITE_GRAFANA_HOST=https://your-org.grafana.net
VITE_GRAFANA_URL=https://your-org.grafana.net
VITE_GRAFANA_ID=your-grafana-user-id
VITE_GRAFANA_SECRET=your-grafana-api-key
VITE_GRAFANA_ENVIRONMENT=test