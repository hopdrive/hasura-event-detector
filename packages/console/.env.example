# Auth Configuration (disabled by default for local dev)
VITE_AUTH_ENABLED=false
CONSOLE_PASSWORD=your-console-password
# AUTH_TOKEN_SECRET=optional-separate-signing-secret

# Per-environment Hasura (server-side, read by /api/config function)
TEST_GRAPHQL_ENDPOINT=https://gql-test.hopdrive.io/v1/graphql
TEST_HASURA_ADMIN_SECRET=your-test-admin-secret
PROD_GRAPHQL_ENDPOINT=https://gql.hopdrive.io/v1/graphql
PROD_HASURA_ADMIN_SECRET=your-prod-admin-secret

# Local dev fallback (used when VITE_AUTH_ENABLED=false)
VITE_GRAPHQL_ENDPOINT=http://localhost:8080/v1/graphql
VITE_HASURA_ADMIN_SECRET=your-local-admin-secret

# Shared Grafana (server-side)
GRAFANA_ID=your-grafana-user-id
GRAFANA_SECRET=your-grafana-api-key
# GRAFANA_SECRET is the Grafana service account token (set in Netlify)

# Client-side Grafana (safe to bundle)
VITE_GRAFANA_LOKI_HOST=https://your-org.grafana.net
VITE_GRAFANA_URL=https://your-org.grafana.net
VITE_GRAFANA_ENVIRONMENT=test